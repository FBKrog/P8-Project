  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TutorialManager
  playTutorialOnStart: 1
  vrCamera: {fileID: 0}
  steps:
  - subtitleText: Aim your arm by holding the right hand trigger button. Release
      the trigger to extend arm.
    displayDuration: 0
    completesObjective: 
  - subtitleText: Grab the Orb of Teleportation by holding the right hand select
      button.
    displayDuration: 0
    completesObjective: 
  - subtitleText: Retract your arm with the orb in hand by pressing the trigger button.
    displayDuration: 0
    completesObjective: 
  - subtitleText: Place the orb in the empty slot on your left hand.
    displayDuration: 0
    completesObjective: 
  - subtitleText: You can now teleport by tilting the left thumbstick forward.
    displayDuration: 4
    completesObjective: OrbObjective
  - subtitleText: Teleport through the door to the pressure plate ahead.
    stepId: TeleportStep
    displayDuration: 0
    completesObjective:
  - subtitleText: Step on the pressure plate to start the puzzle.
    stepId: PlateStep
    displayDuration: 0
    completesObjective:
  - subtitleText: Remove the Orb from your hand and place it on the pedestal.
    stepId: OrbPedestalStep
    displayDuration: 0
    completesObjective: PuzzleIntroObjective
  - subtitleText: Objective complete! Continue through the level.
    displayDuration: 0
    completesObjective:
